# ── Credentials & secrets ─────────────────────────────────────────────────────
.env

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
.venv/
env/
.env.local

# ── Log files (keep sample files, ignore live rotating log) ───────────────────
logs/trading_bot.log
logs/trading_bot.log.*
!logs/*_sample.log

# ── Distribution / packaging ───────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg

# ── pytest cache ───────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── IDE files ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS files ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
